# Copy this file to .env in project root.

# Required for current pipeline
GEMINI_API_KEY="your_gemini_api_key_here"
API_CORS_ORIGINS="http://127.0.0.1:5500,http://localhost:5500"

# Embedding configuration
EMBED_MODEL="gemini-embedding-001"
EMBED_BATCH_SIZE="100"
EMBED_DELAY="0.0"

# Retrieval and ranking
TOPK_HYBRID="80"
TOPK_RERANK="11"
SEMANTIC_WEIGHT="0.45"
LEXICAL_WEIGHT="0.20"
RECENCY_WEIGHT="0.35"
RECENCY_HALFLIFE_YEARS="7.0"

# 1 = prioritize recency, 0 = disable
PREFER_RECENT_DEFAULT="1"

# Response generation (Gemini)
GENERATION_MODEL="gemini-3-flash-preview"
GENERATION_FALLBACK_MODEL="gemini-2.5-flash"
GENERATION_MAX_OUTPUT_TOKENS="3600"
GENERATION_THINKING_BUDGET="128"

# Text-to-Speech (TTS)
# gemini_native (default): Gemini native audio path
# legacy_google: Google Cloud Text-to-Speech Neural2 (rollback path)
TTS_PROVIDER="gemini_native"

# Legacy Google TTS profile (default rollback path)
GOOGLE_TTS_API_KEY=""
GOOGLE_TTS_VOICE_NAME="pt-BR-Neural2-B"
GOOGLE_TTS_MAX_CHARS="5000"
GOOGLE_TTS_REQUEST_TIMEOUT_MS="45000"

# Gemini native TTS profile (optional)
GEMINI_TTS_MODEL="gemini-2.5-pro-preview-tts"
GEMINI_TTS_VOICE="charon"
GEMINI_TTS_MAX_CHARS="5000"
GEMINI_TTS_STREAM_MAX_CHARS="1200"
GEMINI_TTS_REQUEST_TIMEOUT_MS="45000"
GEMINI_TTS_REQUEST_RETRY_ATTEMPTS="0"
GEMINI_TTS_MODEL_MAX_ATTEMPTS="1"
GEMINI_TTS_PREFETCH_CONCURRENCY="1"

# Context assembly for richer answers
CONTEXT_MAX_PASSAGES_PER_DOC="5"
CONTEXT_MAX_PASSAGE_CHARS="1000"
CONTEXT_MAX_DOC_CHARS="2500"

# Automatic jurisprudence update (STF/STJ)
JURIS_UPDATE_TARGET_YEAR="2026"
JURIS_UPDATE_INCLUDE_STF="1"
JURIS_UPDATE_INCLUDE_STJ="1"
JURIS_UPDATE_VISIBLE_BROWSER="1"
JURIS_UPDATE_EMBED_MODEL="gemini-embedding-001"
JURIS_UPDATE_EMBED_BATCH_SIZE="16"
JURIS_UPDATE_STJ_REPAIR_WITH_GEMINI="1"
JURIS_UPDATE_STJ_REPAIR_MODEL="gemini-3-flash-preview"
JURIS_UPDATE_STJ_REPAIR_MIN_CONFIDENCE="0.62"
JURIS_UPDATE_STJ_REPAIR_MAX_RECORDS_PER_PDF="24"
JURIS_UPDATE_STRICT_COMPLETENESS="1"
JURIS_UPDATE_EMBED_FALLBACK_ON_QUOTA="1"
JURIS_UPDATE_JOB_POLL_MS="1500"
RATE_LIMIT_JURIS_UPDATE_PER_HOUR="4"

# Optional explicit Chromium executable for STF collection.
# Leave empty when using bundled Playwright browser.
PLAYWRIGHT_CHROMIUM_EXECUTABLE=""
